# .exports - Environment variables

# Editor
export EDITOR="code --wait"
export VISUAL="$EDITOR"

# XDG Base Directory Specification
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"

# Locale
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

# History
export HISTFILE="$HOME/.zsh_history"
export HISTSIZE=100000
export SAVEHIST=100000

# Make less more friendly
export LESS="-R --use-color"
export LESSHISTFILE="-"   # Don't save less history

# Colored man pages (uses bat if available, otherwise color codes)
if command -v bat &>/dev/null; then
  export MANPAGER="sh -c 'col -bx | bat -l man -p'"
  export MANROFF_OPT="-c"
else
  export LESS_TERMCAP_mb=$'\e[1;31m'   # begin bold
  export LESS_TERMCAP_md=$'\e[1;36m'   # begin blink
  export LESS_TERMCAP_me=$'\e[0m'      # reset bold/blink
  export LESS_TERMCAP_se=$'\e[0m'      # reset reverse
  export LESS_TERMCAP_so=$'\e[01;33m'  # begin reverse
  export LESS_TERMCAP_ue=$'\e[0m'      # reset underline
  export LESS_TERMCAP_us=$'\e[1;32m'   # begin underline
fi

# bat theme (used for syntax highlighting)
export BAT_THEME="Monokai Extended"

# fzf default options
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_DEFAULT_OPTS="
  --height 40%
  --layout=reverse
  --border
  --preview 'bat --color=always --style=numbers --line-range=:50 {}'
  --preview-window=right:50%:wrap
"
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'

# Go
export GOPATH="$HOME/go"

# ghq — git repository manager
export GHQ_ROOT="$HOME/Developer"

# Prevent Homebrew from sending analytics
export HOMEBREW_NO_ANALYTICS=1
export HOMEBREW_NO_ENV_HINTS=1
